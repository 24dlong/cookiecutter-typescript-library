{
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <25",
    "pnpm": ">=11.0.0 <12"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "types": "./dist/main.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "10.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.9.5",
    "semantic-release": "25.0.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint:actionlint": "./.cache/bin/actionlint -color ./.github/workflows/*.yml",
    "lint": "eslint . && prettier . --check --ignore-unknown && pnpm lint:actionlint",
    "lint:fix": "eslint --fix && prettier . --write --ignore-unknown && pnpm lint:actionlint",
    "setup:actionlint": "./scripts/setup-actionlint.sh",
    "prepare": "husky",
    "preinstall": "make registry-auth"
  }
}
