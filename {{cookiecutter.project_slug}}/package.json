{
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <25",
    "pnpm": ">=10.0.0 <12"
  },
  "packageManager": "pnpm@11.2.2",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "types": "./dist/main.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@eslint/js": "10.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.1",
    "vitest": "4.1.5"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint:actionlint": "./.cache/bin/actionlint -color ./.github/workflows/*.yml",
    "lint": "eslint . && prettier . --check --ignore-unknown && pnpm lint:actionlint",
    "lint:fix": "eslint --fix && prettier . --write --ignore-unknown && pnpm lint:actionlint",
    "setup:actionlint": "./scripts/setup-actionlint.sh",
    "prepare": "husky"
  }
}
