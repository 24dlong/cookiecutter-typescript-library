{
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <25",
    "pnpm": ">=10.0.0 <11"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "types": "./dist/main.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "@eslint/js": "10.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.3.1",
    "prettier": "3.8.1",
    "semantic-release": "25.0.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.0.18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint:actionlint": "./.cache/bin/actionlint -color ./.github/workflows/*.yml",
    "lint": "eslint . && prettier . --check --ignore-unknown && pnpm lint:actionlint",
    "lint:fix": "eslint --fix && prettier . --write --ignore-unknown && pnpm lint:actionlint",
    "setup:actionlint": "./scripts/setup-actionlint.sh",
    "prepare": "husky"
  }
}
